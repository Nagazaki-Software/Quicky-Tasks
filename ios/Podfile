$FirebaseAnalyticsWithoutAdIdSupport = true

# iOS mínimo — mantenha 15; se algum pod exigir mais, suba pra '16.0'
platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Braintree e Flutter funcionam muito bem com frameworks estáticos
use_frameworks! :linkage => :static
# ⚠️ Evite use_modular_headers! aqui; se algum plugin reclamar, a gente liga pontualmente.

flutter_ios_podfile_setup

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Mantive seu Firestore via Invertase (ok)
  pod 'FirebaseFirestore',
      :git => 'https://github.com/invertase/firestore-ios-sdk-frameworks.git',
      :tag => '11.13.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # ✅ FORÇA o alvo mínimo em TODAS as pods (não delete isso)
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # ✅ Swift/Xcode modernos (Braintree iOS v6 usa toolchain novo)
      config.build_settings['SWIFT_VERSION'] = '5.9'

      # ✅ Warnings NÃO viram erro (depreciações do PayPal não vão te derrubar)
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-deprecated-declarations'
    end
  end
end

# Seu target de notificação por imagem
target 'ImageNotification' do
  use_frameworks! :linkage => :static
  pod 'Firebase/Messaging'
end
