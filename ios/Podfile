source 'https://cdn.cocoapods.org/'
# Habilita SDK do Analytics sem ID de Ads
$FirebaseAnalyticsWithoutAdIdSupport = true

# Plataforma alvo (use "15.0" em vez de "15.0.0")
platform :ios, '15.0'

# Desliga métricas (build mais rápido no CI)
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

# Configurações padrão do Flutter para iOS
flutter_ios_podfile_setup

target 'Runner' do
  # Frameworks estáticos evitam conflitos de linkagem Swift
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Instala todos os pods de Flutter + plugins
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # --- Braintree: adiciona explicitamente os módulos usados pelo plugin ---
  pod 'BraintreeCore'
  pod 'BraintreeCard'
  pod 'BraintreeThreeDSecure'
  pod 'BraintreeDataCollector'
  # Se for usar PayPal/Venmo: descomente
  # pod 'BraintreePayPal'
  # pod 'BraintreeVenmo'

  # 🔥 Removido:
  # - GoogleUtilities (vem transitivo pelo Firebase)
  # - FirebaseFirestore via Git da Invertase (causa erros de tag/HEAD)
  #   Deixe o FlutterFire resolver versões pelo CocoaPods (CDN acima).
end

# (Opcional) Target da extensão de notificação com Messaging
target 'ImageNotification' do
  use_frameworks! :linkage => :static
  pod 'Firebase/Messaging'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Fixar o alvo iOS do projeto dos Pods
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Garantir Swift 5
      config.build_settings['SWIFT_VERSION'] = '5.0'
      # Definições de permissões (se você usa permission_handler)
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_LOCATION=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_NOTIFICATIONS=1',
      ]
    end
  end
end
