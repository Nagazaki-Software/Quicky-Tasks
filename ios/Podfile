# ios/Podfile
source 'https://cdn.cocoapods.org/'
platform :ios, '14.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Evita warning do master specs
install! 'cocoapods', :warn_for_unused_master_specs_repo => false

project 'Runner', {
  'Debug'   => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcconfig = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  raise "Generated.xcconfig não encontrado. Rode `flutter pub get`." unless File.exist?(generated_xcconfig)
  File.foreach(generated_xcconfig) do |line|
    m = line.match(/FLUTTER_ROOT\=(.*)/)
    return m[1].strip if m
  end
  raise "FLUTTER_ROOT não encontrado no Generated.xcconfig."
end

require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))
flutter_ios_podfile_setup

# ===== App principal =====
target 'Runner' do
  # Gera módulos Swift sem modular headers globais
  use_frameworks! :linkage => :static

  # Plugins do Flutter (inclui FirebaseMessaging via plugin flutterfire)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Seus pods extras
  pod 'Braintree',               '~> 6.36'
  pod 'Braintree/Card',          '~> 6.36'
  pod 'Braintree/ThreeDSecure',  '~> 6.36'
  pod 'Braintree/DataCollector', '~> 6.36'
end

# ===== Extensão de Notificação com imagem =====
# Ajuste o nome do target abaixo se for diferente em seu projeto Xcode
target 'ImageNotification' do
  # Herdar search paths do alvo pai (inclui coisas do Flutter quando necessário)
  inherit! :search_paths

  # Módulos Swift como frameworks estáticos (necessário p/ Firebase* em extensão)
  use_frameworks! :linkage => :static

  # Dependências específicas da extensão
  pod 'Firebase/Messaging'
  # Se você manipula mídia/imagem na extensão e usa SDWebImage, ative:
  # pod 'SDWebImage'
end

post_install do |installer|
  installer.pods_project.targets.each do |t|
    flutter_additional_ios_build_settings(t)
    t.build_configurations.each do |c|
      c.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # Deixe o CocoaPods gerenciar libs Swift
      c.build_settings.delete('ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES')
    end
  end
end
