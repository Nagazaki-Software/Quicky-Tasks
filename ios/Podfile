# Fonte oficial dos specs
source 'https://cdn.cocoapods.org/'

platform :ios, '15.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Descobre o FLUTTER_ROOT a partir do Generated.xcconfig
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    m = line.match(/FLUTTER_ROOT\=(.*)/)
    return m[1].strip if m
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

# Helper do Flutter (.rb!)
require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))

flutter_ios_podfile_setup

target 'Runner' do
  # Linkagem estática reduz dor de cabeça com frameworks e velocidade de linkedição
  use_frameworks! :linkage => :static

  # Plugins do Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # ===== Braintree via CocoaPods (NÃO via git) =====
  pod 'Braintree',               '~> 6.36'
  pod 'Braintree/Card',          '~> 6.36'
  pod 'Braintree/ThreeDSecure',  '~> 6.36'
  pod 'Braintree/DataCollector', '~> 6.36'
  # ================================================
end

target 'ImageNotification' do
  use_frameworks! :linkage => :static
  pod 'Firebase/Messaging'
end

post_install do |installer|
  # ⚙️ ADAPTADOR: chama flutter_additional_ios_build_settings do jeito que o teu Flutter espera
  if self.respond_to?(:flutter_additional_ios_build_settings)
    # arity: -1 => aceita qualquer número de args; 1 => 1 arg; 0 => sem args (raríssimo)
    ar = method(:flutter_additional_ios_build_settings).arity
    case ar
    when 1
      # Versões que esperam TARGET
      installer.pods_project.targets.each do |t|
        flutter_additional_ios_build_settings(t)
      end
    when 0
      # Quase não aparece, mas deixo por segurança
      flutter_additional_ios_build_settings
    else
      # Versões antigas que esperam INSTALLER
      flutter_additional_ios_build_settings(installer)
    end
  end

  # Garante iOS mínimo e Swift coerentes em todos os pods
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end
end
