$FirebaseAnalyticsWithoutAdIdSupport = true

# Suba a base mínima. Braintree e amigos já miram 15+.
platform :ios, '15.0'

# Silencia warnings de pods (não do seu app).
inhibit_all_warnings!

# CocoaPods analytics atrasa build do Flutter
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Seus pods
  pod 'GoogleUtilities'

  # Instala pods do Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # ⚠️ Recomendo usar o Firestore oficial para reduzir atrito com outras libs.
  # Se você REALMENTE precisar do fork da Invertase, comente a linha oficial e descomente a alternativa.
  pod 'FirebaseFirestore'
  # pod 'FirebaseFirestore', :git => 'https://github.com/invertase/firestore-ios-sdk-frameworks.git', :tag => '11.13.0'
end

# Target de extensão de notificação
target 'ImageNotification' do
  use_frameworks! :linkage => :static
  pod 'Firebase/Messaging'
  pod 'GoogleUtilities'
end

post_install do |installer|
  # Ajusta flags do projeto de Pods (onde vivem Braintree, Firebase, etc.)
  installer.pods_project.targets.each do |t|
    t.build_configurations.each do |config|
      # Garante o target mínimo alinhado com o platform
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # Não tratar warning como erro nos pods
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

      # Silencia especificamente "deprecated declarations" em Obj-C dos pods
      other_cflags = config.build_settings['OTHER_CFLAGS']
      if other_cflags.nil? || other_cflags == ''
        config.build_settings['OTHER_CFLAGS'] = ['$(inherited)', '-Wno-deprecated-declarations']
      elsif other_cflags.is_a?(Array)
        config.build_settings['OTHER_CFLAGS'] = other_cflags + ['-Wno-deprecated-declarations']
      else
        # String -> vira array herdado + flag
        config.build_settings['OTHER_CFLAGS'] = ['$(inherited)', other_cflags, '-Wno-deprecated-declarations']
      end
    end
  end

  # Ajustes também no Runner (se quiser manter as suas defines)
  installer.aggregate_targets.each do |aggregate|
    aggregate.user_project.native_targets.each do |t|
      t.build_configurations.each do |config|
        # Suas defines de permissões (mantidas)
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
        wanted = %w[
          PERMISSION_CAMERA=1
          PERMISSION_PHOTOS=1
          PERMISSION_LOCATION=1
          PERMISSION_MICROPHONE=1
          PERMISSION_NOTIFICATIONS=1
        ]
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = (defs + wanted).uniq

        # Garanta a mesma política de warnings no app
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      end
    end
  end

  # Flutter helper padrão
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
