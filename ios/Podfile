# Podfile gerado para Flutter + Braintree (CocoaPods)
source 'https://cdn.cocoapods.org/'
platform :ios, '15.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Descobre o FLUTTER_ROOT de forma robusta:
# 1) Lê do ios/Flutter/Generated.xcconfig (padrão do Flutter)
# 2) Se não existir, tenta ENV['FLUTTER_ROOT']
# 3) Se ainda não existir, roda `flutter pub get` e tenta de novo
def flutter_root
  generated_xcconfig = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)

  if File.exist?(generated_xcconfig)
    File.foreach(generated_xcconfig) do |line|
      m = line.match(/FLUTTER_ROOT\=(.*)/)
      return m[1].strip if m
    end
  end

  if ENV['FLUTTER_ROOT'] && !ENV['FLUTTER_ROOT'].empty? && File.directory?(ENV['FLUTTER_ROOT'])
    return ENV['FLUTTER_ROOT']
  end

  # Tenta regenerar silenciosamente
  system('bash', '-lc', 'cd .. && flutter pub get 1>/dev/null 2>&1')
  if File.exist?(generated_xcconfig)
    File.foreach(generated_xcconfig) do |line|
      m = line.match(/FLUTTER_ROOT\=(.*)/)
      return m[1].strip if m
    end
  end

  raise "Generated.xcconfig não encontrado e ENV['FLUTTER_ROOT'] não definida. Rode `flutter pub get` na raiz do projeto."
end

# Helper do Flutter (.rb)
require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))

flutter_ios_podfile_setup

target 'Runner' do
  # Linkagem estática = menos treta de linkagem
  use_frameworks! :linkage => :static

  # Plugins do Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # 👉 Braintree via CocoaPods (NÃO via :git). Linha 6.x
  pod 'Braintree',               '~> 6.36'
  pod 'Braintree/Card',          '~> 6.36'
  pod 'Braintree/ThreeDSecure',  '~> 6.36'
  pod 'Braintree/DataCollector', '~> 6.36'
end

# Se tiver targets extras, descomente/ajuste:
# target 'ImageNotification' do
#   use_frameworks! :linkage => :static
#   pod 'Firebase/Messaging'
# end

# ===== Wrapper seguro para diferenças de assinatura do helper do Flutter =====
def _call_flutter_build_settings_safely(installer)
  return unless self.respond_to?(:flutter_additional_ios_build_settings)
  arity = -1
  begin
    arity = method(:flutter_additional_ios_build_settings).arity
  rescue
    # mantém -1
  end

  if arity == 1
    # versões recentes: recebe TARGET
    installer.pods_project.targets.each do |t|
      begin
        flutter_additional_ios_build_settings(t)
      rescue NoMethodError, ArgumentError
        # tenta outras variantes abaixo
      end
    end
    return
  end

  if arity == 0
    begin
      flutter_additional_ios_build_settings
      return
    rescue NoMethodError, ArgumentError
    end
  end

  # fallback: versões antigas: recebe INSTALLER
  begin
    flutter_additional_ios_build_settings(installer)
  rescue NoMethodError, ArgumentError
    # não deixa o hook quebrar
  end
end
# ============================================================================

post_install do |installer|
  # NUNCA chamar o helper direto: usa o wrapper
  _call_flutter_build_settings_safely(installer)

  # Garante iOS mínimo e Swift coerentes
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end
end
