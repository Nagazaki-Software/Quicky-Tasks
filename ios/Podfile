source 'https://cdn.cocoapods.org/'
platform :ios, '15.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# ✅ Vale para TODOS os targets (Runner + extensões)
use_modular_headers!
use_frameworks! :linkage => :static

install! 'cocoapods',
  :warn_for_unused_master_specs_repo => false,
  :generate_multiple_pod_projects => false,
  :integrate_targets => true

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcconfig = File.expand_path(File.join('..','Flutter','Generated.xcconfig'), __FILE__)
  raise "Generated.xcconfig não encontrado. Rode `flutter pub get`." unless File.exist?(generated_xcconfig)
  File.foreach(generated_xcconfig) do |line|
    m = line.match(/FLUTTER_ROOT\=(.*)/); return m[1].strip if m
  end
  raise "FLUTTER_ROOT não encontrado no Generated.xcconfig."
end

require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))
flutter_ios_podfile_setup

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # ⚠️ Evite declarar Braintree manualmente se o plugin já traz.
  # Se precisar mesmo travar versão, deixe aqui, mas cuidado com duplicação.
  # pod 'Braintree/Core',          '~> 6.36'
  # pod 'Braintree/Card',          '~> 6.36'
  # pod 'Braintree/ThreeDSecure',  '~> 6.36'
  # pod 'Braintree/DataCollector', '~> 6.36'
  # pod 'Braintree/ApplePay',      '~> 6.36'
end

target 'ImageNotification' do
  inherit! :search_paths
end

post_install do |installer|
  # ✅ Chame o helper do Flutter com o INSTALLER (uma vez só)
  flutter_additional_ios_build_settings(installer)

  # Ajustes extras (opcional)
  installer.pods_project.targets.each do |t|
    t.build_configurations.each do |c|
      c.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      c.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      c.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
    end
  end
end
